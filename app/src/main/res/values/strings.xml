  <string name="pref_swipe_threshold_summary">Minimum vertical travel required to register a valid swipe. Lower values trigger more easily but increase false positives.</string>
  <string name="pref_edge_exclusion_summary">Ignore touches starting within this distance from any screen edge. Prevents conflicts with system back gestures and navigation bars.</string>
  <string name="pref_finger_landing_title">Finger landing window</string>
  <string name="pref_finger_landing_summary">Maximum time threshold between the first and third finger touching the display. Increase this if your fingers don\'t land perfectly in sync to ensure the gesture registers.</string>
